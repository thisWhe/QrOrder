ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_FORWARDEDHEADERS_ENABLED=true
PublicBaseUrl=https://menu.example.com
AllowedHosts=menu.example.com
ConnectionStrings__Default=Server=SQL_SERVER;Database=QrOrderDb;User Id=QrOrderApp;Password=CHANGE_ME;Encrypt=True;TrustServerCertificate=False;MultipleActiveResultSets=True
Jwt__Issuer=QrOrder
Jwt__Audience=QrOrderStaff
Jwt__Key=CHANGE_ME_WITH_AT_LEAST_48_RANDOM_CHARACTERS
Seed__DemoData=false
Database__ApplyMigrationsOnStartup=false
Storage__UploadsPath=D:\QrOrderData\uploads
DataProtection__KeysPath=D:\QrOrderData\keys
Serilog__WriteTo__1__Args__path=D:\QrOrderData\logs\qrorder-.log
Bootstrap__SuperAdminEmail=owner@example.com
Bootstrap__SuperAdminPassword=CHANGE_ME_STRONG_PASSWORD
